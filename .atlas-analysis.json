  "publicApiSurface": [
    "POST /api/chat - AI chat streaming endpoint",
    "POST /api/metadata - Chat metadata generation",
    "POST /api/auth/* - Authentication endpoints",
    "searchContent - Semantic search for Canvas content",
    "getClassAssignments - Fetch assignments from Canvas",
    "getTodos - Get user's todo list",
    "createTodo - Create new todo item",
    "updateTodo - Update existing todo",
    "deleteTodo - Delete todo item",
    "createStudySet - Generate flashcards for studying",
    "memory - Store and retrieve user information"
  ]
