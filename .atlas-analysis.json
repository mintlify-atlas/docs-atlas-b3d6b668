  "keyFeatures": [
    "AI-powered chat with streaming responses and multiple specialized agents",
    "Educational dashboard for managing classes, assignments, and todos",
    "Study tools with flashcards and question sets",
    "Canvas LMS integration with semantic search",
    "Cross-platform web and mobile applications",
    "Persistent AI memory for personalized assistance",
    "Real-time task management with calendar integration",
    "Secure authentication with Better-Auth"
